    fi
    echo

    # --- Quick reference ---
    echo -e "${C_BOLD}${C_CYAN}Quick setup:${C_RESET}"
    echo -e "  ${C_DIM}# Set a provider key${C_RESET}"
    echo -e "  export ${C_YELLOW}OPENAI_API_KEY${C_RESET}='sk-...'"
    echo -e ""
    echo -e "  ${C_DIM}# Set default provider${C_RESET}"
