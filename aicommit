    echo -e "  ${C_DIM}# Override provider/model for a single run${C_RESET}"
    echo -e "  aicommit ${C_GREEN}--provider${C_RESET} anthropic ${C_GREEN}--model${C_RESET} claude-3-5-sonnet-latest"
}

# ---------- Self-update ----------
GITHUB_REPO="apertacodex/aicommit"
GITHUB_RAW_URL="https://raw.githubusercontent.com/${GITHUB_REPO}/main/aicommit"
GITHUB_API_URL="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"

self_update() {
    echo -e "${C_CYAN}${C_BOLD}Checking for updates...${C_RESET}"

    # Fetch latest release version from GitHub
    local latest_version
    latest_version=$(curl -sfL "$GITHUB_API_URL" | jq -r '.tag_name // empty' 2>/dev/null | sed 's/^v//')

    if [[ -z "$latest_version" ]]; then
        echo -e "${C_RED}Error: Could not fetch the latest release from GitHub.${C_RESET}"
        echo -e "${C_DIM}Check your network connection or try again later.${C_RESET}"
        exit 1
    fi

    echo -e "  Installed version: ${C_BOLD}v${VERSION}${C_RESET}"
    echo -e "  Latest version:    ${C_BOLD}v${latest_version}${C_RESET}"

    # Compare versions
    if [[ "$VERSION" == "$latest_version" ]]; then
        echo -e "\n${C_GREEN}✅ You are already running the latest version.${C_RESET}"
        exit 0
    fi

    echo -e "\n${C_YELLOW}⬆ New version available: v${latest_version}${C_RESET}"

    # Find where the current binary lives
    local current_bin
    current_bin=$(command -v aicommit 2>/dev/null || true)

    if [[ -z "$current_bin" ]]; then
        echo -e "${C_RED}Error: Cannot locate the aicommit binary in PATH.${C_RESET}"
        exit 1
    fi

    # Resolve symlinks to get the actual file
    local actual_bin
    if command -v readlink &>/dev/null; then
        actual_bin=$(readlink -f "$current_bin" 2>/dev/null || echo "$current_bin")
    else
        actual_bin="$current_bin"
    fi

    echo -e "  Updating: ${C_DIM}${actual_bin}${C_RESET}"

    # Download to a temp file first
    local tmp_file
    tmp_file=$(mktemp /tmp/aicommit-update-XXXXXX)

    if ! curl -fsSL "$GITHUB_RAW_URL" -o "$tmp_file"; then
        echo -e "${C_RED}Error: Failed to download the latest version.${C_RESET}"
        rm -f "$tmp_file"
        exit 1
    fi

    # Verify the download looks like the aicommit script
    if ! head -1 "$tmp_file" | grep -q '#!/usr/bin/env bash'; then
        echo -e "${C_RED}Error: Downloaded file does not appear to be a valid aicommit script.${C_RESET}"
        rm -f "$tmp_file"
        exit 1
    fi

    chmod +x "$tmp_file"

    # Install — use sudo if we can't write to the target directly
    if [[ -w "$actual_bin" ]]; then
        mv "$tmp_file" "$actual_bin"
    elif sudo -n true 2>/dev/null; then
        sudo mv "$tmp_file" "$actual_bin"
    else
        echo -e "${C_YELLOW}Elevated permissions required to update ${actual_bin}${C_RESET}"
        sudo mv "$tmp_file" "$actual_bin"
    fi

    echo -e "\n${C_GREEN}✅ Successfully updated aicommit: v${VERSION} → v${latest_version}${C_RESET}"
    exit 0
}

set -euo pipefail

# ---------- Provider constants ----------
VALID_PROVIDERS="openai anthropic gemini groq ollama custom"
CONFIG_FILE="$HOME/.aicommitrc"

# ---------- Argument handling ----------
NO_PUSH=false
ASSUME_YES=false
UPDATE_CHANGELOG=false
CLI_PROVIDER=""
CLI_MODEL=""
AUTO_PULL=false
RELEASE_MODE=false
RELEASE_ARG=""
REMAP=false

while (( "$#" )); do
    case "$1" in
        --no-push|-n)  NO_PUSH=true ;;
        --yes|-y)      ASSUME_YES=true ;;
        --pull)        AUTO_PULL=true ;;
        --changelog|-c) UPDATE_CHANGELOG=true ;;
        --remap)       REMAP=true ;;
        --provider|-p)
            shift
            if [[ -z "${1:-}" || "${1:-}" =~ ^- ]]; then
                echo "Error: --provider requires a value."
                echo "Valid providers: $VALID_PROVIDERS"
                exit 1
            fi
            CLI_PROVIDER="$1"
            ;;
        --model|-m)
            shift
            if [[ -z "${1:-}" || "${1:-}" =~ ^- ]]; then
                echo "Error: --model requires a value."
                exit 1
            fi
            CLI_MODEL="$1"
            ;;
        --release|-r)
            RELEASE_MODE=true
            if [[ -n "${2:-}" && ! "$2" =~ ^- ]]; then
                RELEASE_ARG="$2"
                shift
            fi
            ;;
        --update)
            show_banner
            self_update
            ;;
        -v|-V|--version)
            show_banner
            exit 0
            ;;
        -h|--help)
            show_banner
            show_help
            exit 0
            ;;
        *)
            echo "Warning: unknown option \"$1\" ignored."
            ;;
    esac
    shift
done

# ---------- Repository checks ----------
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: Not inside a git repository."
    exit 1
fi

# ---------- Environment checks ----------
if ! command -v jq &>/dev/null; then
    echo "Error: jq is not installed. Please install it first."
    echo "Ubuntu/Debian: sudo apt-get install jq"
    echo "macOS: brew install jq"
    exit 1
fi

# ---------- Provider helpers ----------
provider_available() {
    case "$1" in
        openai)    [[ -n "${OPENAI_API_KEY:-}" ]] ;;
        anthropic) [[ -n "${ANTHROPIC_API_KEY:-}" ]] ;;
        gemini)    [[ -n "${GEMINI_API_KEY:-}" ]] ;;
        groq)      [[ -n "${GROQ_API_KEY:-}" ]] ;;
        ollama)    command -v ollama &>/dev/null && curl -sf http://localhost:11434/api/tags &>/dev/null ;;
        custom)    [[ -n "${AICOMMIT_CUSTOM_API_URL:-}" && -n "${AICOMMIT_CUSTOM_API_KEY:-}" ]] ;;
        *)         return 1 ;;
    esac
}

detect_first_provider() {
    for p in openai anthropic gemini groq ollama custom; do
        if provider_available "$p"; then
            echo "$p"
            return 0
        fi
    done
    return 1
}

# ---------- Resolve provider ----------
PROVIDER=""
MODEL=""

# 1. CLI flag
if [[ -n "$CLI_PROVIDER" ]]; then
    PROVIDER="$CLI_PROVIDER"
# 2. Environment variable
elif [[ -n "${AICOMMIT_PROVIDER:-}" ]]; then
    PROVIDER="$AICOMMIT_PROVIDER"
# 3. Config file
elif [[ -f "$CONFIG_FILE" ]]; then
    cfg_provider=$(grep -E '^AICOMMIT_PROVIDER=' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | tr -d '[:space:]"'"'" || true)
    if [[ -n "$cfg_provider" ]]; then
        PROVIDER="$cfg_provider"
    fi
fi

# 4. Auto-detect
if [[ -z "$PROVIDER" ]]; then
    PROVIDER=$(detect_first_provider || true)
fi

if [[ -z "$PROVIDER" ]]; then
    echo "Error: No AI provider configured or detected."
    echo
    echo "Set one of these environment variables:"
    echo "  export OPENAI_API_KEY='your-key'       (for OpenAI)"
    echo "  export ANTHROPIC_API_KEY='your-key'     (for Anthropic/Claude)"
    echo "  export GEMINI_API_KEY='your-key'        (for Google Gemini)"
    echo "  export GROQ_API_KEY='your-key'          (for Groq)"
    echo "  Install and run Ollama locally           (for Ollama)"
    echo "  export AICOMMIT_CUSTOM_API_URL + AICOMMIT_CUSTOM_API_KEY (for custom)"
    echo
    echo "Or set a default: echo 'AICOMMIT_PROVIDER=openai' >> ~/.aicommitrc"
    exit 1
fi

# Validate provider name
if ! echo "$VALID_PROVIDERS" | grep -qw "$PROVIDER"; then
    echo "Error: Unknown provider '$PROVIDER'."
    echo "Valid providers: $VALID_PROVIDERS"
    exit 1
fi

# Resolve model override precedence:
# CLI --model > provider-specific env default > built-in default
if [[ -n "$CLI_MODEL" ]]; then
    MODEL="$CLI_MODEL"
else
    case "$PROVIDER" in
        openai)    MODEL="${AICOMMIT_OPENAI_MODEL:-gpt-4o-mini}" ;;
        anthropic) MODEL="${AICOMMIT_ANTHROPIC_MODEL:-claude-sonnet-4-20250514}" ;;
        gemini)    MODEL="${AICOMMIT_GEMINI_MODEL:-gemini-2.0-flash}" ;;
        groq)      MODEL="${AICOMMIT_GROQ_MODEL:-llama-3.3-70b-versatile}" ;;
        ollama)    MODEL="${AICOMMIT_OLLAMA_MODEL:-}" ;;
        custom)    MODEL="${AICOMMIT_CUSTOM_MODEL:-gpt-4o-mini}" ;;
    esac
fi

# Validate provider has required credentials
if ! provider_available "$PROVIDER"; then
    case "$PROVIDER" in
        openai)    echo "Error: OPENAI_API_KEY is not set." ;;
        anthropic) echo "Error: ANTHROPIC_API_KEY is not set." ;;
        gemini)    echo "Error: GEMINI_API_KEY is not set." ;;
        groq)      echo "Error: GROQ_API_KEY is not set." ;;
        ollama)    echo "Error: Ollama is not installed or the server is not running (http://localhost:11434)." ;;
        custom)    echo "Error: AICOMMIT_CUSTOM_API_URL and/or AICOMMIT_CUSTOM_API_KEY is not set." ;;
    esac
    exit 1
fi

# Resolve Ollama model if not explicitly set
if [[ "$PROVIDER" == "ollama" && -z "$MODEL" ]]; then
    MODEL=$(curl -sf http://localhost:11434/api/tags 2>/dev/null | jq -r '.models[0].name // empty' 2>/dev/null || true)
    if [[ -z "$MODEL" ]]; then
        echo "Error: No Ollama models found. Pull a model first: ollama pull llama3.2" >&2
        exit 1
    fi
fi

# ---------- Provider API functions ----------
SYSTEM_PROMPT="You are a helpful assistant that generates git commit messages following the Conventional Commits specification. Focus on the actual code changes to determine the type and scope. Keep the message concise but complete, under 50 characters for the first line if possible."

build_user_prompt() {
    cat <<EOF
Generate a concise and descriptive git commit message for the following changes.
Follow the conventional commits specification (https://www.conventionalcommits.org/).
Use one of these types: feat, fix, docs, style, refactor, test, chore.

Rules:
1. Format first line as: <type>(<scope>): <description>
2. The first line should be under 50 characters if possible
3. After the first line, add a blank line and then bullet points for details
4. Each bullet point should start with a hyphen
5. Keep bullet points short and clear
6. Focus on WHAT changed and WHY, not HOW

Here are the changes:

$1
EOF
}

call_openai() {
    local user_prompt="$1"
    local model="${MODEL:-${AICOMMIT_OPENAI_MODEL:-gpt-4o-mini}}"
    local payload
    payload=$(jq -n \
        --arg model "$model" \
        --arg content "$SYSTEM_PROMPT" \
        --arg prompt "$user_prompt" \
        '{
            model: $model,
            messages: [
                {role: "system",   content: $content},
                {role: "user",     content: $prompt}
            ],
            temperature: 0.7,
            max_tokens: 2048
        }')

    local response
    response=$(curl -s https://api.openai.com/v1/chat/completions \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $OPENAI_API_KEY" \
        -d "$payload")

    if echo "$response" | jq -e '.error' &>/dev/null; then
        local err_msg
        err_msg=$(echo "$response" | jq -r '.error.message')
        echo "Error from OpenAI API: $err_msg" >&2
        return 1
    fi

    echo "$response" | jq -r '.choices[0].message.content'
}

call_anthropic() {
    local user_prompt="$1"
    local model="${MODEL:-${AICOMMIT_ANTHROPIC_MODEL:-claude-sonnet-4-20250514}}"
    local payload
    payload=$(jq -n \
        --arg model "$model" \
        --arg system "$SYSTEM_PROMPT" \
        --arg prompt "$user_prompt" \
        '{
            model: $model,
            max_tokens: 2048,
            system: $system,
            messages: [
                {role: "user", content: $prompt}
            ]
        }')

    local response
    response=$(curl -s https://api.anthropic.com/v1/messages \
        -H "Content-Type: application/json" \
