# ---------- Release helpers ----------

RELEASE_SYSTEM_PROMPT="You are a versioning assistant. You analyze git commit messages and determine the appropriate version bump according to Semantic Versioning (semver.org) and Conventional Commits. Versions may be X, X.Y, or X.Y.Z — preserve the component count of the current version.

Rules:
- MAJOR: commits with 'BREAKING CHANGE' in footer/body, or '!' after type/scope (e.g., 'feat!:', 'fix(api)!:')
- MINOR: commits with type 'feat' (new features)
- PATCH: commits with type 'fix', 'docs', 'style', 'refactor', 'perf', 'test', 'chore', or any other type

Respond with ONLY one word: major, minor, or patch. Nothing else."

# Per-project, AI-generated version map + bump script (committed to the repo)
AICOMMIT_DIR=".aicommit"
VERSION_MAP_FILE="${AICOMMIT_DIR}/version-map.json"
BUMP_SCRIPT_FILE="${AICOMMIT_DIR}/bump-version.sh"

DISCOVERY_SYSTEM_PROMPT="You are a build-tooling assistant. You are given a list of 'path:line:content' matches where version-looking numbers appear in a project. Identify every location that holds THE PROJECT'S OWN version — the version that is incremented on each release. Versions may be X, X.Y, or X.Y.Z.

INCLUDE locations such as: a package.json \"version\" field, a VERSION file, the version under [package] in pyproject.toml or Cargo.toml, version constants in source code (e.g. VERSION=, __version__, APP_VERSION), and VERSION= assignments in shell scripts/executables.

EXCLUDE: dependency/requirement versions, lockfiles, the project's CHANGELOG history, example/test fixtures, documentation samples, and any unrelated version-looking numbers.

Respond with ONLY a compact JSON object, no markdown fences and no prose:
{\"files\":[{\"path\":\"relative/path\",\"anchor\":\"short literal text on the version line\"}]}

The 'anchor' must be a short literal substring that appears on the SAME line as the version and uniquely identifies it (e.g. 'VERSION=', '\"version\":', '__version__', 'version ='). It is used later to locate the line for replacement. If no project version exists, respond with {\"files\":[]}."

ai_detect_bump() {
    local commits="$1"
    local current_version="$2"
    local user_prompt="Analyze these commit messages and determine the version bump type:

$commits

Current version: $current_version

Respond with exactly one word: major, minor, or patch"

    local saved_system="$SYSTEM_PROMPT"
    SYSTEM_PROMPT="$RELEASE_SYSTEM_PROMPT"

    local result
    case "$PROVIDER" in
        openai)    result=$(call_openai "$user_prompt") ;;
        anthropic) result=$(call_anthropic "$user_prompt") ;;
        gemini)    result=$(call_gemini "$user_prompt") ;;
        groq)      result=$(call_groq "$user_prompt") ;;
        ollama)    result=$(call_ollama "$user_prompt") ;;
        custom)    result=$(call_custom "$user_prompt") ;;
    esac

    SYSTEM_PROMPT="$saved_system"

    result=$(echo "$result" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
    if [[ "$result" != "major" && "$result" != "minor" && "$result" != "patch" ]]; then
        echo "Error: AI returned unexpected bump type: '$result'" >&2
        return 1
    fi
    echo "$result"
}

# Ask the AI which files hold the project version. Prints a JSON object
# {"files":[{"path":..,"anchor":..}]} on success; returns non-zero otherwise.
ai_discover_version_files() {
    local candidates
    candidates=$(git grep -nE '[0-9]+(\.[0-9]+(\.[0-9]+)?)?' 2>/dev/null \
        | grep -viE '(^|/)(CHANGELOG[^:]*|.*\.lock|package-lock\.json|yarn\.lock|composer\.lock):|node_modules/|(^|/)\.aicommit/' \
        | head -300 || true)
    if [[ -z "$candidates" ]]; then
        echo "No version-like strings found in tracked files." >&2
        return 1
    fi

    local user_prompt="Identify the project's own version location(s) from these matches:

${candidates}

Return the JSON now."

    local saved_system="$SYSTEM_PROMPT"
    SYSTEM_PROMPT="$DISCOVERY_SYSTEM_PROMPT"
    local result
    case "$PROVIDER" in
        openai)    result=$(call_openai "$user_prompt") ;;
        anthropic) result=$(call_anthropic "$user_prompt") ;;
        gemini)    result=$(call_gemini "$user_prompt") ;;
        groq)      result=$(call_groq "$user_prompt") ;;
        ollama)    result=$(call_ollama "$user_prompt") ;;
        custom)    result=$(call_custom "$user_prompt") ;;
    esac
    SYSTEM_PROMPT="$saved_system"

    # Strip any markdown fences the model may add
    result=$(echo "$result" | sed '/^```/d')
    if ! echo "$result" | jq -e '.files | type == "array"' &>/dev/null; then
        echo "Error: AI did not return valid version-file JSON." >&2
        return 1
    fi
    echo "$result"
}

# Render the deterministic, project-specific bump script from a manifest JSON.
generate_bump_script() {
    local manifest="$1"
    mkdir -p "$AICOMMIT_DIR"
    echo "$manifest" > "$VERSION_MAP_FILE"

    {
        cat <<'HEADER'
#!/usr/bin/env bash
# Auto-generated by aicommit — do not edit by hand.
# Regenerate after adding/removing version files with: aicommit --remap
#
# Increments THIS project's version across all known files.
# Usage: .aicommit/bump-version.sh <new_version> [old_version]
#   new_version  the version to write (with or without a leading 'v')
#   old_version  optional; if given, only that exact version is replaced
set -euo pipefail

NEW="${1:?usage: bump-version.sh <new_version> [old_version]}"
NEW="${NEW#v}"
OLD="${2:-}"
SEMVER='[0-9]+(\.[0-9]+(\.[0-9]+)?)?'

# Run from the repo root (parent of this .aicommit directory)
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

bump_line() {
    local file="$1" anchor="$2" esc
    if [[ ! -f "$file" ]]; then
        echo "  skip (missing): $file" >&2
        return 0
    fi
    # Escape only ERE metacharacters so the literal anchor is a safe sed address
    esc=$(printf '%s' "$anchor" | sed 's/[][\\^$.*+?(){}|]/\\&/g')
    if [[ -n "$OLD" ]]; then
        sed -i -E "/$esc/ s/${OLD//./\\.}/${NEW}/g" "$file"
    else
        sed -i -E "/$esc/ s/${SEMVER}/${NEW}/g" "$file"
    fi
    echo "  updated: $file" >&2
}

HEADER

        echo "$manifest" | jq -r '.files[] | "bump_line " + (.path | @sh) + " " + (.anchor | @sh)'
    } > "$BUMP_SCRIPT_FILE"

    chmod +x "$BUMP_SCRIPT_FILE"
}

# Read the current version recorded at a manifest entry's anchored line.
# The anchor is a literal substring, so match it with grep -F (no regex).
read_manifest_version() {
    local file="$1" anchor="$2"
    [[ -f "$file" ]] || return 1
    grep -F -- "$anchor" "$file" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+(\.[0-9]+)?)?' | head -1
}

# Ensure a per-project version map + bump script exist. Runs AI discovery
# (one call, cached afterwards) when missing or when --remap is given.
# Returns 0 when a usable bump script is available, non-zero otherwise.
ensure_version_map() {
    if [[ "$REMAP" != "true" && -f "$BUMP_SCRIPT_FILE" && -f "$VERSION_MAP_FILE" ]]; then
        return 0
    fi

    echo -e "${C_CYAN}Discovering version files with AI (provider: $PROVIDER, model: ${MODEL:-auto})...${C_RESET}" >&2
    local manifest
    if ! manifest=$(ai_discover_version_files); then
        return 1
    fi

    local count
    count=$(echo "$manifest" | jq '.files | length')
    if [[ "$count" -eq 0 ]]; then
        echo -e "${C_YELLOW}AI found no project version files.${C_RESET}" >&2
        return 1
    fi

    echo "" >&2
    echo -e "${C_BOLD}AI located these version locations:${C_RESET}" >&2
    echo "$manifest" | jq -r '.files[] | "  • " + .path + "   (anchor: " + .anchor + ")"' >&2
    echo "" >&2

    if ! $ASSUME_YES; then
        read -p "Save this map to ${VERSION_MAP_FILE} and generate ${BUMP_SCRIPT_FILE}? [Y/n] " reply
        reply=$(echo "$reply" | tr '[:upper:]' '[:lower:]')
        if [[ "$reply" == "n" ]]; then
            echo "Skipping version-map generation." >&2
            return 1
        fi
    fi

    generate_bump_script "$manifest"
    REMAP=false   # avoid re-discovering again within the same run
    echo -e "${C_GREEN}✓ Generated ${BUMP_SCRIPT_FILE}${C_RESET}" >&2
    return 0
}

detect_project_versions() {
    local -n _sources=$1
    local -n _versions=$2

    # Git tag
    local tag_ver
    tag_ver=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
    if [[ -n "$tag_ver" ]]; then
        tag_ver="${tag_ver#v}"
        if validate_version "$tag_ver"; then
            _sources+=("git tag")
            _versions+=("$tag_ver")
        fi
    fi

    # If a per-project version map exists, it is authoritative for files:
    # read each recorded location and skip the built-in heuristics below.
    if [[ -f "$VERSION_MAP_FILE" ]]; then
        local mp ma mv
        while IFS=$'\t' read -r mp ma; do
            [[ -n "$mp" ]] || continue
            mv=$(read_manifest_version "$mp" "$ma" || true)
            if validate_version "$mv"; then
                _sources+=("$mp")
                _versions+=("$mv")
            fi
        done < <(jq -r '.files[] | [.path, .anchor] | @tsv' "$VERSION_MAP_FILE" 2>/dev/null)
        return 0
    fi

    # package.json
    if [[ -f "package.json" ]]; then
        local pkg_ver
        pkg_ver=$(grep -oP '"version"\s*:\s*"\K[^"]+' package.json 2>/dev/null || true)
        if validate_version "$pkg_ver"; then
            _sources+=("package.json")
            _versions+=("$pkg_ver")
        fi
    fi

    # VERSION file
    if [[ -f "VERSION" ]]; then
        local file_ver
        file_ver=$(tr -d '[:space:]' < VERSION)
        if validate_version "$file_ver"; then
            _sources+=("VERSION")
            _versions+=("$file_ver")
        fi
    fi

    # version.ts / version.js
    for vfile in lib/version.ts lib/version.js src/version.ts src/version.js; do
        if [[ -f "$vfile" ]]; then
            local v
            v=$(grep -oP '(APP_VERSION|VERSION|version)\s*=\s*"\K[^"]+' "$vfile" 2>/dev/null || true)
            if validate_version "$v"; then
                _sources+=("$vfile")
                _versions+=("$v")
            fi
        fi
    done

    # pyproject.toml
    if [[ -f "pyproject.toml" ]]; then
        local py_ver
        py_ver=$(grep -oP '^version\s*=\s*"\K[^"]+' pyproject.toml 2>/dev/null || true)
        if validate_version "$py_ver"; then
            _sources+=("pyproject.toml")
            _versions+=("$py_ver")
        fi
    fi

    # Cargo.toml
    if [[ -f "Cargo.toml" ]]; then
        local cargo_ver
        cargo_ver=$(sed -n '/^\[package\]/,/^\[/p' Cargo.toml 2>/dev/null | grep -oP '^version\s*=\s*"\K[^"]+' || true)
        if validate_version "$cargo_ver"; then
            _sources+=("Cargo.toml")
            _versions+=("$cargo_ver")
        fi
    fi

    # Inline VERSION="X.Y.Z" in shell scripts and other executables
    local script_file
    while IFS= read -r -d '' script_file; do
        [[ -f "$script_file" ]] || continue
        file "$script_file" 2>/dev/null | grep -q "text" || continue
        local sv
        sv=$(grep -oP '^VERSION="\K[0-9]+(\.[0-9]+(\.[0-9]+)?)?(?=")' "$script_file" 2>/dev/null | head -1 || true)
        if validate_version "$sv"; then
            _sources+=("$script_file")
            _versions+=("$sv")
        fi
    done < <(find . -maxdepth 2 \( -name "*.sh" -o -type f -executable \) -not -path './.git/*' -not -path './node_modules/*' -print0 2>/dev/null)
}

# Validate a version string: accepts X, X.Y, or X.Y.Z
validate_version() {
    [[ "$1" =~ ^[0-9]+(\.[0-9]+(\.[0-9]+)?)?$ ]]
}

# Parse a version into components, stored in a global array _ver_parts.
# Also sets _ver_components to the count (1, 2, or 3).
parse_version() {
    local IFS='.'
    _ver_parts=($1)
    _ver_components=${#_ver_parts[@]}
}

# Compare two versions that may have different numbers of components.
# Missing components are treated as 0 (so 1.2 == 1.2.0, and 2 > 1.9.9).
# Returns 0 if $1 > $2, 1 otherwise.
semver_gt() {
    local IFS='.'
    local -a a=($1) b=($2)
    local max=${#a[@]}
    (( ${#b[@]} > max )) && max=${#b[@]}
    for ((i = 0; i < max; i++)); do
        local av=${a[i]:-0} bv=${b[i]:-0}
        if (( av > bv )); then return 0; fi
        if (( av < bv )); then return 1; fi
    done
    return 1
}

# Bump a version: $1=current_version, $2=bump_type (major|minor|patch).
# Preserves the component count of the current version.
#   X:     major→X+1,  minor→X+1,  patch→X+1
#   X.Y:   major→X+1.0, minor→X.Y+1, patch→X.Y+1
#   X.Y.Z: standard semver
bump_version() {
    parse_version "$1"
    local n=$_ver_components
    local -a v=("${_ver_parts[@]}")
    case "$2" in
        major)
            v[0]=$((v[0] + 1))
            for ((i = 1; i < n; i++)); do v[i]=0; done
            ;;
        minor)
            if (( n >= 2 )); then
                v[1]=$((v[1] + 1))
                for ((i = 2; i < n; i++)); do v[i]=0; done
            else
                v[0]=$((v[0] + 1))
            fi
            ;;
        patch)
            v[$((n - 1))]=$((v[n - 1] + 1))
            ;;
    esac
    local IFS='.'
    echo "${v[*]}"
}

highest_version() {
    local best="$1"
    shift
    for v in "$@"; do
        if semver_gt "$v" "$best"; then
            best="$v"
        fi
    done
    echo "$best"
}

CONSOLIDATED_VERSION=""

consolidate_versions() {
    CONSOLIDATED_VERSION=""
    local sources=()
    local versions=()
    detect_project_versions sources versions

    if [[ ${#versions[@]} -le 1 ]]; then
        return 0
    fi

    # Check if all versions are the same
    local first="${versions[0]}"
    local all_same=true
    for v in "${versions[@]:1}"; do
        if [[ "$v" != "$first" ]]; then
            all_same=false
            break
        fi
    done

    if $all_same; then
        return 0
    fi

    # Versions differ - show them and prompt
    echo ""
    echo -e "${C_YELLOW}Version mismatch detected across project files:${C_RESET}"
    echo "  -----------------------------------------------"
    for i in "${!sources[@]}"; do
        echo -e "  ${C_BOLD}${versions[$i]}${C_RESET}  ← ${sources[$i]}"
    done
    echo "  -----------------------------------------------"

    local best
    best=$(highest_version "${versions[@]}")

    if ! $ASSUME_YES; then
        echo ""
        echo -e "  Recommended: use the highest version ${C_GREEN}${C_BOLD}${best}${C_RESET}"
        read -p "  Consolidate all to v${best}? [Y/n/custom] " reply
        reply=$(echo "$reply" | tr '[:upper:]' '[:lower:]')
        if [[ "$reply" == "n" ]]; then
            echo "  Skipping version consolidation."
            return 0
        elif [[ "$reply" =~ ^[0-9]+(\.[0-9]+(\.[0-9]+)?)?$ ]]; then
            best="$reply"
        fi
    fi

    echo ""
    echo -e "  Consolidating all version sources to ${C_GREEN}${C_BOLD}v${best}${C_RESET}..."
    update_project_version "$best"

    # Also update the git tag baseline if it was behind
    local tag_ver
    tag_ver=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
    tag_ver="${tag_ver#v}"
    if [[ -n "$tag_ver" && "$tag_ver" != "$best" ]]; then
        echo -e "  ${C_YELLOW}Note:${C_RESET} Git tag is at v${tag_ver}. The new release will be based on v${best}."
    fi

    # Stage consolidated changes
    git add -A 2>/dev/null || true

    CONSOLIDATED_VERSION="$best"
}

update_project_version() {
    local next_version="$1"
    local updated=false

    # Preferred path: use the project-specific, AI-discovered bump script.
    # ensure_version_map runs AI discovery once (then caches) when needed.
    if ensure_version_map; then
        echo "Bumping version to ${next_version} via ${BUMP_SCRIPT_FILE}..."
        bash "$BUMP_SCRIPT_FILE" "$next_version"
        return 0
    fi

    echo -e "${C_DIM}Using built-in version detectors...${C_RESET}"

    # package.json
    if [[ -f "package.json" ]]; then
        echo "Updating package.json to ${next_version}..."
        if command -v npm &>/dev/null; then
            npm version "$next_version" --no-git-tag-version &>/dev/null || \
                sed -i "s/\"version\": \".*\"/\"version\": \"${next_version}\"/" package.json
        else
            sed -i "s/\"version\": \".*\"/\"version\": \"${next_version}\"/" package.json
        fi
        updated=true
    fi

    # VERSION file
    if [[ -f "VERSION" ]]; then
        echo "Updating VERSION file to ${next_version}..."
        echo "$next_version" > VERSION
        updated=true
    fi

    # version.ts / version.js (common patterns)
    for vfile in lib/version.ts lib/version.js src/version.ts src/version.js; do
        if [[ -f "$vfile" ]]; then
            if grep -qE '(APP_VERSION|VERSION|version)\s*=\s*"' "$vfile"; then
                echo "Updating ${vfile} to ${next_version}..."
                sed -i -E "s/(APP_VERSION|VERSION|version)(\s*=\s*)\"[^\"]+\"/\1\2\"${next_version}\"/" "$vfile"
                updated=true
            fi
        fi
    done

    # pyproject.toml
    if [[ -f "pyproject.toml" ]]; then
        if grep -q '^version\s*=' pyproject.toml; then
            echo "Updating pyproject.toml to ${next_version}..."
            sed -i "s/^version\s*=\s*\".*\"/version = \"${next_version}\"/" pyproject.toml
            updated=true
        fi
    fi

    # Cargo.toml (first version = line only, under [package])
    if [[ -f "Cargo.toml" ]]; then
        if sed -n '/^\[package\]/,/^\[/p' Cargo.toml | grep -q '^version\s*='; then
            echo "Updating Cargo.toml to ${next_version}..."
            sed -i "0,/^version\s*=\s*\".*\"/{s/^version\s*=\s*\".*\"/version = \"${next_version}\"/}" Cargo.toml
            updated=true
        fi
    fi

    # Inline VERSION="X.Y.Z" in shell scripts and other executables
    local script_file
    while IFS= read -r -d '' script_file; do
        [[ -f "$script_file" ]] || continue
        file "$script_file" 2>/dev/null | grep -q "text" || continue
        if grep -qP '^VERSION="[0-9]+(\.[0-9]+(\.[0-9]+)?)?"' "$script_file" 2>/dev/null; then
            echo "Updating ${script_file} to ${next_version}..."
            sed -i "s/^VERSION=\"[0-9]\+\(\.[0-9]\+\(\.[0-9]\+\)\?\)\?\"/VERSION=\"${next_version}\"/" "$script_file"
            updated=true
        fi
    done < <(find . -maxdepth 2 \( -name "*.sh" -o -type f -executable \) -not -path './.git/*' -not -path './node_modules/*' -print0 2>/dev/null)

    if ! $updated; then
        echo -e "${C_YELLOW}Warning: No version files found in current project to update.${C_RESET}"
    fi
}

generate_changelog_from_commits() {
    local tag="$1"
    local changelog_file="CHANGELOG.md"

    if [[ ! -f "$changelog_file" ]]; then
        cat > "$changelog_file" << 'CLEOF'
# Changelog

All notable changes to this project will be documented in this file.

The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.1.0/),
and this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).

## [Unreleased]

CLEOF
    fi

    # Ensure [Unreleased] section exists before the first version entry
    if ! grep -q "## \[Unreleased\]" "$changelog_file"; then
        local temp_file
        temp_file=$(mktemp)
        awk '
            !inserted && /^## \[/ {
                print "## [Unreleased]"
                print ""
                inserted=1
            }
            { print }
        ' "$changelog_file" > "$temp_file"
        mv "$temp_file" "$changelog_file"
    fi

    local log
    log=$(git log "${tag}..HEAD" --pretty=format:"%h %s" 2>/dev/null)
    [[ -z "$log" ]] && return 0

    local added="" fixed="" changed=""
    local hash subject commit_type desc entry
    while IFS= read -r line; do
        hash="${line%% *}"
        subject="${line#* }"
        commit_type=$(echo "$subject" | grep -oP '^[a-z]+' || echo "chore")
        desc=$(echo "$subject" | sed 's/^[a-z]\+[^:]*: //')
        entry="- $desc ($hash)"
        case "$commit_type" in
            feat) added+="${entry}"$'\n' ;;
            fix)  fixed+="${entry}"$'\n' ;;
            *)    changed+="${entry}"$'\n' ;;
        esac
    done <<< "$log"

    local insert=""
    [[ -n "$added" ]]   && insert+="### Added"$'\n'"${added}"$'\n'
    [[ -n "$fixed" ]]   && insert+="### Fixed"$'\n'"${fixed}"$'\n'
    [[ -n "$changed" ]] && insert+="### Changed"$'\n'"${changed}"$'\n'
    [[ -z "$insert" ]] && return 0

    local temp_file
    temp_file=$(mktemp)
    awk -v section="$insert" '
        /## \[Unreleased\]/ {
            print
            print ""
            printf "%s", section
            next
        }
        { print }
    ' "$changelog_file" > "$temp_file"
    mv "$temp_file" "$changelog_file"
}

do_release() {
    # Must be in a git repo
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo "Error: Not inside a git repository."
        exit 1
    fi

    # Must be on main branch
    local current_branch
    current_branch=$(git rev-parse --abbrev-ref HEAD)
    if [[ "$current_branch" != "main" ]]; then
        echo -e "${C_RED}Error:${C_RESET} Releases must be created from the ${C_BOLD}main${C_RESET} branch."
        echo "  Current branch: $current_branch"
        exit 1
    fi

    # If there are uncommitted changes, run the normal commit flow first
    if ! git diff-index --quiet HEAD -- 2>/dev/null || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
        echo -e "${C_CYAN}Uncommitted changes detected. Running commit flow first...${C_RESET}"
        echo ""

        local full_diff
        full_diff=$(get_all_changes)
        if [[ -z "$full_diff" ]]; then
            echo "No changes detected."
        else
            echo "Analyzing changes and generating commit message (provider: $PROVIDER, model: ${MODEL:-auto})..."
            local gen_msg
            gen_msg=$(call_ai_provider "$full_diff") || exit 1
            gen_msg=$(echo "$gen_msg" | sed '/^```/d')

            echo -e "\nAI-generated commit message:"
            echo "--------------------------------"
            echo -e "$gen_msg"
            echo "--------------------------------"

            local final_msg="$gen_msg"
            if ! $ASSUME_YES; then
                read -p "Use this commit message? [Y/n/e] (Y = use, n = abort, e = edit): " choice
                choice=$(echo "$choice" | tr '[:upper:]' '[:lower:]')
                case "$choice" in
                    n) echo "Release aborted."; exit 0 ;;
                    e)
                        local tmpfile
                        tmpfile=$(mktemp /tmp/commit_msg.XXXXXX)
                        echo "$gen_msg" > "$tmpfile"
                        ${EDITOR:-nano} "$tmpfile"
                        final_msg=$(<"$tmpfile")
                        rm -f "$tmpfile"
                        ;;
                    *) final_msg="$gen_msg" ;;
                esac
            fi

            git add -A
            git commit -m "$final_msg"
            echo -e "\n${C_GREEN}Changes committed.${C_RESET}"
            echo ""
        fi
    fi

    if $AUTO_PULL; then
        echo "Pulling from origin/$current_branch with --no-rebase..."
        if ! git pull --no-rebase origin "$current_branch"; then
            echo -e "${C_RED}⚠️  Pull failed. Please resolve conflicts and try again.${C_RESET}"
            exit 1
        fi
        echo "Pull completed."
        echo ""
    fi

    # Get latest tag
    local latest_tag
    latest_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
    if [[ -z "$latest_tag" ]]; then
        echo -e "${C_YELLOW}No existing version tags found.${C_RESET}"
        local initial_ver="0.1.0"
        if ! $ASSUME_YES; then
            read -p "Enter initial version [${initial_ver}]: " user_ver
            if [[ -n "$user_ver" ]]; then
                user_ver="${user_ver#v}"
                if ! validate_version "$user_ver"; then
                    echo -e "${C_RED}Error:${C_RESET} Invalid version format. Use X, X.Y, or X.Y.Z"
                    exit 1
                fi
                initial_ver="$user_ver"
            fi
        fi
        if git rev-parse "v${initial_ver}" >/dev/null 2>&1; then
            echo -e "${C_YELLOW}Tag v${initial_ver} already exists, using it as baseline.${C_RESET}"
            latest_tag="v${initial_ver}"
        else
            echo "Creating initial tag v${initial_ver}..."
            git tag -a "v${initial_ver}" -m "Initial release v${initial_ver}"
            latest_tag="v${initial_ver}"
            echo -e "${C_GREEN}Created tag v${initial_ver}${C_RESET}"
        fi
        echo ""
    fi

    # Check for version mismatches across project files
    consolidate_versions
    
    local current_ver="${latest_tag#v}"
    
    # If consolidation produced a version higher than the tag, use it as baseline
    if [[ -n "$CONSOLIDATED_VERSION" ]]; then
        if semver_gt "$CONSOLIDATED_VERSION" "$current_ver"; then
            current_ver="$CONSOLIDATED_VERSION"
            echo -e "  Using consolidated version ${C_BOLD}v${current_ver}${C_RESET} as baseline for this release."
        fi
    fi

    if ! validate_version "$current_ver"; then
        echo -e "${C_RED}Error:${C_RESET} Latest tag '$latest_tag' is not a valid version (X, X.Y, or X.Y.Z)."
        exit 1
    fi

    parse_version "$current_ver"
    local cur_major="${_ver_parts[0]}"
    local cur_minor="${_ver_parts[1]:-0}"
    local cur_patch="${_ver_parts[2]:-0}"
    local cur_components=$_ver_components

    local bump_type=""
    local next_version=""

    if [[ -z "$RELEASE_ARG" ]]; then
        # AI auto-detect
        local commits
        commits=$(git log "${latest_tag}..HEAD" --pretty=format:"%s" 2>/dev/null)
        if [[ -z "$commits" ]]; then
            if [[ -n "$CONSOLIDATED_VERSION" ]]; then
                next_version="$CONSOLIDATED_VERSION"
                bump_type="explicit"
                echo -e "  ${C_YELLOW}No new commits since ${latest_tag}; releasing consolidated version v${next_version}.${C_RESET}"
            else
                echo -e "${C_RED}Error:${C_RESET} No new commits since ${latest_tag}."
                exit 1
            fi
        else
            local commit_count
            commit_count=$(echo "$commits" | wc -l)
            echo "Analyzing $commit_count commit(s) since ${latest_tag} to determine bump type (provider: $PROVIDER, model: ${MODEL:-auto})..."
            bump_type=$(ai_detect_bump "$commits" "$current_ver") || exit 1
        fi
    elif [[ "$RELEASE_ARG" =~ ^(patch|minor|major)$ ]]; then
        bump_type="$RELEASE_ARG"
    elif [[ "$RELEASE_ARG" =~ ^[0-9]+(\.[0-9]+(\.[0-9]+)?)?$ ]]; then
        next_version="$RELEASE_ARG"
        bump_type="explicit"
    else
        echo -e "${C_RED}Error:${C_RESET} Invalid release argument '$RELEASE_ARG'."
        echo "  Usage: aicommit --release [patch|minor|major|X|X.Y|X.Y.Z]"
        exit 1
    fi

    # Calculate next version if not explicit
    if [[ -z "$next_version" ]]; then
        next_version=$(bump_version "$current_ver" "$bump_type")
    fi

    # Count commits since last tag
    local commit_count
    commit_count=$(git rev-list "${latest_tag}..HEAD" --count 2>/dev/null || echo "0")

    # Show release plan
    echo ""
    echo -e "${C_BOLD}${C_CYAN}Release Plan:${C_RESET}"
    echo "  -----------------------------------------------"
    echo -e "  Current version: ${C_BOLD}${current_ver}${C_RESET} (${latest_tag})"
    echo -e "  New version:     ${C_BOLD}${C_GREEN}${next_version}${C_RESET}"
    echo -e "  Bump type:       ${C_BOLD}${bump_type}${C_RESET}"
    echo -e "  Changes since ${latest_tag}: ${commit_count} commit(s)"
    echo "  -----------------------------------------------"
    echo ""

    if ! $ASSUME_YES; then
        read -p "Proceed with release v${next_version}? [Y/n] " reply
        reply=$(echo "$reply" | tr '[:upper:]' '[:lower:]')
        if [[ "$reply" == "n" ]]; then
            echo "Release cancelled."
            exit 0
        fi
    fi

    # 1. Update version files in the current project
    update_project_version "$next_version"

    # 2. Update CHANGELOG.md
    local changelog_file="CHANGELOG.md"
    local release_date
    release_date=$(date +%Y-%m-%d)

    if $UPDATE_CHANGELOG; then
        if [[ ! -f "$changelog_file" ]] || ! grep -A 20 "## \[Unreleased\]" "$changelog_file" 2>/dev/null | grep -q "^###"; then
            echo "Generating changelog entries from commits since ${latest_tag}..."
            generate_changelog_from_commits "$latest_tag"
        fi
    fi

    if [[ -f "$changelog_file" ]]; then
        if grep -A 10 "## \[Unreleased\]" "$changelog_file" | grep -q "^###"; then
            echo "Updating CHANGELOG.md for v${next_version}..."
            local backup="${changelog_file}.bak"
            cp "$changelog_file" "$backup"

            local unreleased_content
            unreleased_content=$(awk '
                /## \[Unreleased\]/ { in_unreleased=1; next }
                /## \[/ { in_unreleased=0 }
                in_unreleased && /^###/ { print; getline; while(/^-/) { print; if(getline <= 0) break } }
            ' "$changelog_file")

            if [[ -n "$unreleased_content" ]]; then
                awk -v version="$next_version" -v date="$release_date" -v content="$unreleased_content" '
                    /## \[Unreleased\]/ {
                        print
                        print ""
                        print "## [" version "] - " date
                        print content
                        in_unreleased=1
                        next
                    }
                    in_unreleased && /^## \[/ {
                        in_unreleased=0
                    }
                    !in_unreleased { print }
                ' "$backup" > "$changelog_file"
            fi
            rm -f "$backup"
        else
            echo "No unreleased changes in CHANGELOG.md. Skipping CHANGELOG update."
        fi
    fi

    # 3. Commit the release
    echo "Committing release v${next_version}..."
    git add -A
    git commit -m "chore(release): v${next_version}" || true

    # 4. Create annotated tag
    echo "Creating tag v${next_version}..."
    git tag -a "v${next_version}" -m "Release v${next_version}"

    # 5. Push commit + tag (unless --no-push)
    if $NO_PUSH; then
        echo -e "${C_YELLOW}⚡️ Push skipped (--no-push). Commit and tag v${next_version} created locally only.${C_RESET}"
    else
        echo "Pushing to origin..."
        git push origin "$current_branch"
        git push origin "v${next_version}"

        # 6. Create GitHub Release if gh CLI is available
        if command -v gh &>/dev/null; then
            echo "Creating GitHub Release..."
            local release_notes=""
            if [[ -f "$changelog_file" ]]; then
                release_notes=$(sed -n "/## \[${next_version}\]/,/## \[/p" "$changelog_file" | sed '1d;$d' | sed '/^$/d')
            fi
            if [[ -n "$release_notes" ]]; then
                gh release create "v${next_version}" \
                    --title "v${next_version}" \
                    --notes "$release_notes" 2>/dev/null \
                    && echo -e "${C_GREEN}GitHub Release created.${C_RESET}" \
                    || echo -e "${C_YELLOW}Warning: GitHub Release creation failed. You can create it manually.${C_RESET}"
            else
                gh release create "v${next_version}" \
                    --title "v${next_version}" \
                    --generate-notes 2>/dev/null \
                    && echo -e "${C_GREEN}GitHub Release created.${C_RESET}" \
                    || echo -e "${C_YELLOW}Warning: GitHub Release creation failed. You can create it manually.${C_RESET}"
            fi
        fi
    fi

    echo ""
    echo -e "${C_GREEN}${C_BOLD}Release v${next_version} complete!${C_RESET}"
}

# ---------- Constants ----------
MAX_CHAR_LIMIT=20000          # Approximate token limit accounting for OpenAI's token limit
MAX_FILE_CHAR_LIMIT=2000      # Character limit per file content
MAX_DIFF_LINES=100            # Maximum number of diff lines per file

# ---------- Helper functions ----------
truncate_text() {
    local text="$1"
    local max_chars=$2

    if (( ${#text} > max_chars )); then
        local truncated="${text:0:$((max_chars-50))}"
        truncated+="\n... [truncated - $(( (${#text} - max_chars) / 1000 ))K chars omitted] ...\n"
        echo -e "$truncated"
    else
        echo -e "$text"
    fi
}

truncate_diff() {
    local diff_output="$1"
    local max_lines=$2

    local line_count
    line_count=$(echo "$diff_output" | wc -l)

    if (( line_count > max_lines )); then
        local half=$((max_lines / 2))
        local first_part last_part
        first_part=$(echo "$diff_output" | head -n "$half")
        last_part=$(echo "$diff_output" | tail -n "$half")
        echo -e "$first_part"
        echo "... [truncated - $((line_count - max_lines)) lines omitted] ..."
        echo -e "$last_part"
    else
        echo -e "$diff_output"
    fi
}

update_changelog() {
    local commit_msg="$1"
    local changelog_file="CHANGELOG.md"

    # Parse commit message to extract type and description
    local first_line=$(echo "$commit_msg" | head -n 1)
    local commit_type=$(echo "$first_line" | grep -oP '^[a-z]+' || echo "chore")
    local commit_desc=$(echo "$first_line" | sed 's/^[a-z]\+(\?[^)]*)\?: //')

    # Get the short hash of the last commit
    local commit_hash=$(git rev-parse --short=7 HEAD)

    # Map commit type to changelog category
    local category
    case "$commit_type" in
        feat)     category="Added" ;;
        fix)      category="Fixed" ;;
        *)        category="Changed" ;;
    esac

    # Create CHANGELOG.md if it doesn't exist
    if [[ ! -f "$changelog_file" ]]; then
        cat > "$changelog_file" << 'EOF'
# Changelog

All notable changes to this project will be documented in this file.

The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.1.0/),
and this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).

## [Unreleased]

EOF
    fi

    # Check if CHANGELOG was modified in the commit we just made
    # If user manually edited it, we should skip auto-update to avoid conflicts
    if git diff HEAD~1 HEAD --name-only 2>/dev/null | grep -q "^CHANGELOG.md$"; then
        echo "Warning: $changelog_file was modified in this commit. Skipping auto-update."
        return 1
    fi

    # Create entry
    local entry="- $commit_desc ($commit_hash)"

    # Read the current CHANGELOG
    local changelog_content=$(<"$changelog_file")

    # Check if [Unreleased] section exists
    if ! echo "$changelog_content" | grep -q "## \[Unreleased\]"; then
        # Add [Unreleased] section at the top after the header
        local header=$(echo "$changelog_content" | sed -n '1,/^$/p')
        local rest=$(echo "$changelog_content" | sed '1,/^$/d')
        changelog_content="${header}

## [Unreleased]

${rest}"
    fi

    # Check if category exists under [Unreleased]
    if echo "$changelog_content" | sed -n '/## \[Unreleased\]/,/## \[/p' | grep -q "### $category"; then
        # Category exists - insert entry after the category header
        local temp_file=$(mktemp)
        awk -v cat="### $category" -v entry="$entry" '
            /## \[Unreleased\]/ { in_unreleased=1 }
            /## \[/ && !/## \[Unreleased\]/ { in_unreleased=0 }
            in_unreleased && $0 ~ cat {
                print
                getline
                print entry
                print $0
                next
            }
            { print }
        ' "$changelog_file" > "$temp_file"
        mv "$temp_file" "$changelog_file"
    else
        # Category doesn't exist - create it under [Unreleased]
        local temp_file=$(mktemp)
        awk -v cat="### $category" -v entry="$entry" '
            /## \[Unreleased\]/ {
                print
                print ""
                print cat
                print entry
                inserted=1
                next
            }
            { print }
        ' "$changelog_file" > "$temp_file"
        mv "$temp_file" "$changelog_file"
    fi

    # Stage the CHANGELOG and amend the commit
    git add "$changelog_file"
    git commit --amend --no-edit

    return 0
}

# ---------- Gather diff ----------
get_all_changes() {
    local changes="" total_chars=0 truncated=false

    # Summary header
    changes+="=== Summary of Changes ===\n"

    # ---- Staged ----
    local staged=$(git diff --cached --name-status)
    if [[ -n $staged ]]; then
        changes+="=== Staged Changes ===\n"
        changes+="Files changed:\n$staged\n\n"

        local staged_diff=$(git diff --cached --color=never)
        local staged_diff_truncated=$(truncate_diff "$staged_diff" $MAX_DIFF_LINES)
        changes+="Detailed changes:\n$staged_diff_truncated\n\n"
        total_chars=$((total_chars + ${#staged_diff_truncated}))
    fi

    # ---- Unstaged ----
    if (( total_chars < MAX_CHAR_LIMIT * 3 / 4 )); then
        local unstaged=$(git diff --name-status)
        if [[ -n $unstaged ]]; then
            changes+="=== Unstaged Changes ===\n"
            changes+="Files changed:\n$unstaged\n\n"

            local unstaged_diff=$(git diff --color=never)
            local unstaged_diff_truncated=$(truncate_diff "$unstaged_diff" $MAX_DIFF_LINES)
            changes+="Detailed changes:\n$unstaged_diff_truncated\n\n"
            total_chars=$((total_chars + ${#unstaged_diff_truncated}))
        fi
    else
        truncated=true
        changes+="\n... [Some changes omitted due to size limitations] ...\n\n"
    fi

    # ---- Untracked ----
    if (( total_chars < MAX_CHAR_LIMIT * 7 / 8 )) && ! $truncated; then
        local untracked=$(git ls-files --others --exclude-standard)
        if [[ -n $untracked ]]; then
            changes+="=== Untracked Files ===\n"
            local file_limit=5 count=0
            while IFS= read -r file && (( count < file_limit )) && (( total_chars < MAX_CHAR_LIMIT )); do
                [[ -f $file ]] || continue
                ((count++))
                changes+="New file: $file\n"
                if file "$file" | grep -q "text"; then
                    local content truncated_content
                    content=$(cat "$file")
                    truncated_content=$(truncate_text "$content" $MAX_FILE_CHAR_LIMIT)
                    changes+="Content:\n$truncated_content\n\n"
                    total_chars=$((total_chars + ${#truncated_content}))
                else
                    changes+="(Binary file)\n\n"
                fi
                (( total_chars > MAX_CHAR_LIMIT * 9 / 10 )) && break
            done <<< "$untracked"

            local total_untracked
            total_untracked=$(echo "$untracked" | wc -l)
            (( total_untracked > file_limit )) && \
                changes+="Note: Only showing $count of $total_untracked untracked files\n"
        fi
    else
        changes+="\n... [Untracked files omitted due to size limitations] ...\n\n"
    fi

    # Final truncation safeguard
    if (( ${#changes} > MAX_CHAR_LIMIT )); then
        truncate_text "$changes" $MAX_CHAR_LIMIT
    else
        echo -e "$changes"
    fi
}

# ---------- Main flow ----------

# If release mode, run release flow and exit
if $RELEASE_MODE; then
    do_release
    exit 0
fi

# Standalone: rediscover version files and (re)generate the project bump script
if $REMAP; then
    if ensure_version_map; then
        echo -e "${C_GREEN}✓ Version map ready at ${VERSION_MAP_FILE}${C_RESET}"
    else
        echo -e "${C_YELLOW}Version map was not generated.${C_RESET}"
        exit 1
    fi
    exit 0
fi

FULL_DIFF=$(get_all_changes)

if [[ -z $FULL_DIFF ]]; then
    echo "No changes detected."
    exit 0
fi

echo "Analyzing changes and generating commit message (provider: $PROVIDER, model: ${MODEL:-auto})..."

GENERATED_MSG=$(call_ai_provider "$FULL_DIFF") || exit 1
GENERATED_MSG=$(echo "$GENERATED_MSG" | sed '/^```/d')   # strip possible fences

# ---- User review ----
echo -e "\nAI‑generated commit message:"
echo "--------------------------------"
echo -e "$GENERATED_MSG"
echo "--------------------------------"

if $ASSUME_YES; then
    FINAL_MSG="$GENERATED_MSG"
else
    read -p "Use this commit message? [Y/n/e] (Y = use, n = abort, e = edit): " choice
    choice=$(echo "$choice" | tr '[:upper:]' '[:lower:]')

    case "$choice" in
        n) echo "Commit aborted."; exit 0 ;;
        e)
            TMPFILE=$(mktemp /tmp/commit_msg.XXXXXX)
            echo "$GENERATED_MSG" > "$TMPFILE"
            ${EDITOR:-nano} "$TMPFILE"
            FINAL_MSG=$(<"$TMPFILE")
            rm -f "$TMPFILE"
            ;;
        *) FINAL_MSG="$GENERATED_MSG" ;;
    esac
fi

# ---- Final confirmation ----
echo -e "\nFinal commit message:"
echo "--------------------------------"
echo -e "$FINAL_MSG"
echo "--------------------------------"
if ! $ASSUME_YES; then
    read -p "Press Enter to commit (Ctrl+C to abort) … "
fi

# ---- Auto pull (if requested) ----
if $AUTO_PULL; then
    CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
    echo "Pulling from origin/$CURRENT_BRANCH with --no-rebase..."
    if git pull --no-rebase origin "$CURRENT_BRANCH"; then
        echo "✅ Pull completed successfully."
    else
        echo "⚠️ Pull failed. Please resolve conflicts and try again."
        exit 1
    fi
fi

# ---- Commit ----
git add -A
git commit -m "$FINAL_MSG"

echo -e "\n✅ Changes committed successfully!"

# ---- Update CHANGELOG if flag is set ----
if $UPDATE_CHANGELOG; then
    echo "Updating CHANGELOG.md..."
    if update_changelog "$FINAL_MSG"; then
        echo "✅ CHANGELOG.md updated and commit amended."
    else
        echo "⚠️  CHANGELOG.md update skipped."
    fi
fi

# ---- Optional push ----
if ! $NO_PUSH; then
    echo "Pushing to remote..."
    # Push to the current branch's upstream (if set); otherwise fall back to origin HEAD
    CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
    if git rev-parse --abbrev-ref "@{u}" &>/dev/null; then
        # Upstream exists – use default push (preserves upstream config)
        if git push; then
            echo "🚀 Push completed."
        else
            echo "⚠️ Push failed."
            exit 1
        fi
    else
        # No upstream configured – push to origin explicitly
        if git push origin "$CURRENT_BRANCH"; then
            echo "🚀 Push completed."
        else
            echo "⚠️ Push failed."
            exit 1
        fi
    fi
else
    echo "⚡️ Push skipped due to --no-push flag."
fi

# ---- History logging (optional) ----
# Append the exact command used for future reference.
echo "git commit -m \"$FINAL_MSG\"" >> ~/.history

exit 0
